# Frontend environment — ONLY public, non-secret values (INV-012).
# Copy to .env.local. The browser calls the backend through lib/api-client.ts
# using this base URL. NEVER put ANTHROPIC_API_KEY, Robinhood tokens, or JWT
# secrets here — the frontend ships no secrets.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Neon Auth — public auth URL (client-side)
NEXT_PUBLIC_NEON_AUTH_URL=https://your-project.neonauth.region.aws.neon.tech/neondb/auth

# Neon Auth — server-only (never expose to the browser)
NEON_AUTH_BASE_URL=https://your-project.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=  # openssl rand -base64 32

# Comma-separated allowlist for dashboard access (mirrors backend ALLOWED_EMAILS)
ALLOWED_EMAILS=you@example.com
